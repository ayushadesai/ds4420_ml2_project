)
)
knitr::kable(correlation_test_results_B, caption = "Correlation Tests for Group B - # of Reviews")
# Convert to long format for visualization
all_group_data_long <- all_group_data %>%
pivot_longer(
cols = c(Quality, Likelihood, Trust),
names_to = "Measure",
values_to = "Rating"
)
# Create boxplots comparing both groups
boxplot <- ggplot(all_group_data_long, aes(x = Measure, y = Rating, fill = Group)) +
geom_boxplot() +
scale_fill_brewer(palette = "Pastel1") +
labs(
title = "Distribution of Product Ratings",
y = "Rating (1-10)",
x = ""
) +
theme_minimal()
boxplot
ggsave("boxplot.png", plot = boxplot)
# Calculate means and confidence intervals
mean_ratings <- all_group_data_long %>%
group_by(Group, Measure) %>%
summarize(
Mean = mean(Rating, na.rm = TRUE),
SE = sd(Rating, na.rm = TRUE) / sqrt(n()),
CI_lower = Mean - qt(0.975, n()-1) * SE,
CI_upper = Mean + qt(0.975, n()-1) * SE,
.groups = "drop"
)
# Create bar chart with confidence intervals
ggplot(mean_ratings, aes(x = Measure, y = Mean, fill = Group)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.9), width = 0.7) +
geom_errorbar(
aes(ymin = CI_lower, ymax = CI_upper),
position = position_dodge(width = 0.9),
width = 0.25
) +
scale_fill_brewer(palette = "Pastel1") +
labs(
title = "Mean Ratings with 95% Confidence Intervals",
y = "Mean Rating",
x = ""
) +
theme_minimal() +
ylim(0, 10)
# Create histograms for Group A
A_quality <- ggplot(groupA_data_clean, aes(x = Quality)) +
geom_histogram(binwidth = 1, fill = "#FF9999", color = "black") +
labs(
title = "Distribution of Quality Ratings",
x = "Quality Rating",
y = "Count"
) +
theme_minimal() +
scale_x_continuous(breaks = 1:10, limits = c(1, 10))
A_likelihood <- ggplot(groupA_data_clean, aes(x = Likelihood)) +
geom_histogram(binwidth = 1, fill = "#99FF99", color = "black") +
labs(
title = "Distribution of Likelihood Ratings",
x = "Likelihood Rating",
y = "Count"
) +
theme_minimal() +
scale_x_continuous(breaks = 1:10, limits = c(1, 10))
A_trust <- ggplot(groupA_data_clean, aes(x = Trust)) +
geom_histogram(binwidth = 1, fill = "#9999FF", color = "black") +
labs(
title = "Distribution of Trust Ratings",
x = "Trust Rating",
y = "Count"
) +
theme_minimal() +
scale_x_continuous(breaks = 1:10, limits = c(1, 10))
# Display histograms in a grid
histo_a  <- gridExtra::grid.arrange(A_quality, A_likelihood, A_trust, ncol = 2, top = 'Group A - Written Review')
ggsave("histo_a.png", plot = histo_a)
# Create histograms for Group B
B_quality <- ggplot(groupB_data_clean, aes(x = Quality)) +
geom_histogram(binwidth = 1, fill = "#FF9999", color = "black") +
labs(
title = "Distribution of Quality Ratings",
x = "Quality Rating",
y = "Count"
) +
theme_minimal() +
scale_x_continuous(breaks = 1:10, limits = c(1, 10))
B_likelihood <- ggplot(groupB_data_clean, aes(x = Likelihood)) +
geom_histogram(binwidth = 1, fill = "#99FF99", color = "black") +
labs(
title = "Distribution of Likelihood Ratings",
x = "Likelihood Rating",
y = "Count"
) +
theme_minimal() +
scale_x_continuous(breaks = 1:10, limits = c(1, 10))
B_trust <- ggplot(groupB_data_clean, aes(x = Trust)) +
geom_histogram(binwidth = 1, fill = "#9999FF", color = "black") +
labs(
title = "Distribution of Trust Ratings",
x = "Trust Rating",
y = "Count"
) +
theme_minimal() +
scale_x_continuous(breaks = 1:10, limits = c(1, 10))
# Display histograms in a grid
histo_b <- gridExtra::grid.arrange(B_quality, B_likelihood, B_trust, ncol = 2,top = 'Group B - # of Reviews')
ggsave("histo_b.png", plot = histo_b)
View(cor_test_likelihood_trust_B)
View(cor_test_quality_likelihood_B)
