groupA_trust_col <- grep("Trust...24", names(survey_data), fixed = TRUE)
# Group B ratings
groupB_quality_col <- grep("Quality...25", names(survey_data), fixed = TRUE)
groupB_likelihood_col <- grep("Likelihood...26", names(survey_data), fixed = TRUE)
groupB_trust_col <- grep("Trust...27", names(survey_data), fixed = TRUE)
# Create separate dataframes for each group
groupA_data <- survey_data %>%
select(
all_of(c(groupA_quality_col, groupA_likelihood_col, groupA_trust_col))
) %>%
rename(
Quality = names(survey_data)[groupA_quality_col],
Likelihood = names(survey_data)[groupA_likelihood_col],
Trust = names(survey_data)[groupA_trust_col]
) %>%
mutate(Group = "Group A - Written Review")
groupB_data <- survey_data %>%
select(
all_of(c(groupB_quality_col, groupB_likelihood_col, groupB_trust_col))
) %>%
rename(
Quality = names(survey_data)[groupB_quality_col],
Likelihood = names(survey_data)[groupB_likelihood_col],
Trust = names(survey_data)[groupB_trust_col]
) %>%
mutate(Group = "Group B - # of Reviews")
# Combine the two group dataframes
all_group_data <- bind_rows(groupA_data, groupB_data)
# Convert columns to numeric and remove rows with NA values
all_group_data <- all_group_data %>%
mutate(across(c(Quality, Likelihood, Trust), as.numeric)) %>%
drop_na()
# Check the cleaned data
head(all_group_data)
# Filter for Group A data
groupA_data_clean <- all_group_data %>%
filter(Group == "Group A - Written Review") %>%
select(-Group)
# Filter for Group B data
groupB_data_clean <- all_group_data %>%
filter(Group == "Group B - # of Reviews") %>%
select(-Group)
# Number of responses for each group
cat("Number of responses for Group A - Written Review:", nrow(groupA_data_clean), "\n")
cat("Number of responses for Group B - # of Reviews:", nrow(groupB_data_clean), "\n")
# Summary statistics for Group A
summary_stats_A <- groupA_data_clean %>%
summarise(across(everything(),
list(
Mean = mean,
Median = median,
SD = sd,
Min = min,
Max = max
), na.rm = TRUE))
# Display in a more readable format
summary_stats_A %>%
pivot_longer(
everything(),
names_to = c("Variable", "Statistic"),
names_pattern = "(.*)_(.*)"
) %>%
pivot_wider(
names_from = Statistic,
values_from = value
) %>%
knitr::kable(caption = "Descriptive Statistics for Group A - Written Review")
# Summary statistics for Group B
summary_stats_B <- groupB_data_clean %>%
summarise(across(everything(),
list(
Mean = mean,
Median = median,
SD = sd,
Min = min,
Max = max
), na.rm = TRUE))
# Display in a more readable format
summary_stats_B %>%
pivot_longer(
everything(),
names_to = c("Variable", "Statistic"),
names_pattern = "(.*)_(.*)"
) %>%
pivot_wider(
names_from = Statistic,
values_from = value
) %>%
knitr::kable(caption = "Descriptive Statistics for Group B - # of Reviews")
## Group Comparison Results
# Independent t-tests to compare groups
t_quality_groups <- t.test(groupA_data_clean$Quality, groupB_data_clean$Quality)
t_likelihood_groups <- t.test(groupA_data_clean$Likelihood, groupB_data_clean$Likelihood)
t_trust_groups <- t.test(groupA_data_clean$Trust, groupB_data_clean$Trust)
# Create a table to display the results
group_comparison_results <- tibble(
Variable = c("Quality", "Likelihood", "Trust"),
`Group A Mean` = c(
mean(groupA_data_clean$Quality, na.rm = TRUE),
mean(groupA_data_clean$Likelihood, na.rm = TRUE),
mean(groupA_data_clean$Trust, na.rm = TRUE)
),
`Group B Mean` = c(
mean(groupB_data_clean$Quality, na.rm = TRUE),
mean(groupB_data_clean$Likelihood, na.rm = TRUE),
mean(groupB_data_clean$Trust, na.rm = TRUE)
),
`Mean Difference` = c(
mean(groupA_data_clean$Quality, na.rm = TRUE) - mean(groupB_data_clean$Quality, na.rm = TRUE),
mean(groupA_data_clean$Likelihood, na.rm = TRUE) - mean(groupB_data_clean$Likelihood, na.rm = TRUE),
mean(groupA_data_clean$Trust, na.rm = TRUE) - mean(groupB_data_clean$Trust, na.rm = TRUE)
),
`p-value` = c(
t_quality_groups$p.value,
t_likelihood_groups$p.value,
t_trust_groups$p.value
),
`Significantly different?` = c(
ifelse(t_quality_groups$p.value < 0.05, "Yes", "No"),
ifelse(t_likelihood_groups$p.value < 0.05, "Yes", "No"),
ifelse(t_trust_groups$p.value < 0.05, "Yes", "No")
)
)
# Display the results table
print(group_comparison_results)
## Regression Analysis - Group A
# Model 1: Likelihood ~ Quality (Group A)
model1a <- lm(Likelihood ~ Quality, data = groupA_data_clean)
model1a_summary <- summary(model1a)
model1a_r2 <- round(model1a_summary$r.squared, 3)
model1a_slope <- round(coef(model1a)[2], 3)
# Plot: Likelihood ~ Quality (Group A)
p1a <- ggplot(groupA_data_clean, aes(x = Quality, y = Likelihood)) +
geom_point(alpha = 0.6) +
geom_smooth(method = "lm", color = "blue", se = TRUE) +
labs(title = "Group A: Likelihood ~ Quality",
x = "Quality", y = "Likelihood") +
theme_minimal() +
annotate("text", x = min(groupA_data_clean$Quality, na.rm = TRUE) + 0.5,
y = max(groupA_data_clean$Likelihood, na.rm = TRUE) - 0.5,
label = paste0("R^2 = ", model1a_r2, "\nSlope = ", model1a_slope),
hjust = 0)
ggsave("regression_LQ_A.png", plot = p1a)
# Model 2: Trust ~ Quality (Group A)
model2a <- lm(Trust ~ Quality, data = groupA_data_clean)
model2a_summary <- summary(model2a)
model2a_r2 <- round(model2a_summary$r.squared, 3)
model2a_slope <- round(coef(model2a)[2], 3)
# Plot: Trust ~ Quality (Group A)
p2a <- ggplot(groupA_data_clean, aes(x = Quality, y = Trust)) +
geom_point(alpha = 0.6) +
geom_smooth(method = "lm", color = "green", se = TRUE) +
labs(title = "Group A: Trust ~ Quality",
x = "Quality", y = "Trust") +
theme_minimal() +
annotate("text", x = min(groupA_data_clean$Quality, na.rm = TRUE) + 0.5,
y = max(groupA_data_clean$Trust, na.rm = TRUE) - 0.5,
label = paste0("R^2 = ", model2a_r2, "\nSlope = ", model2a_slope),
hjust = 0)
ggsave("regression_TQ_A.png", plot = p2a)
# Model 3: Trust ~ Likelihood (Group A)
model3a <- lm(Trust ~ Likelihood, data = groupA_data_clean)
model3a_summary <- summary(model3a)
model3a_r2 <- round(model3a_summary$r.squared, 3)
model3a_slope <- round(coef(model3a)[2], 3)
# Plot: Trust ~ Likelihood (Group A)
p3a <- ggplot(groupA_data_clean, aes(x = Likelihood, y = Trust)) +
geom_point(alpha = 0.6) +
geom_smooth(method = "lm", color = "purple", se = TRUE) +
labs(title = "Group A: Trust ~ Likelihood",
x = "Likelihood", y = "Trust") +
theme_minimal() +
annotate("text", x = min(groupA_data_clean$Likelihood, na.rm = TRUE) + 0.5,
y = max(groupA_data_clean$Trust, na.rm = TRUE) - 0.5,
label = paste0("R^2 = ", model3a_r2, "\nSlope = ", model3a_slope),
hjust = 0)
ggsave("regression_TL_A.png", plot = p3a)
reg_a <- gridExtra::grid.arrange(p1a, p2a, p3a, ncol = 2, top = 'Group A - Written Review')
## Regression Analysis - Group B
