# Calculate correlation coefficients for Group A
cor_matrix_A <- cor(groupA_data_clean, use = "pairwise.complete.obs")
# Display the correlation matrix
cor_matrix_A %>% round(2) %>% knitr::kable(caption = "Correlation Matrix for Group A - Written Review")
# Test significance of correlations
cor_test_quality_likelihood_A <- cor.test(groupA_data_clean$Quality, groupA_data_clean$Likelihood)
cor_test_quality_trust_A <- cor.test(groupA_data_clean$Quality, groupA_data_clean$Trust)
cor_test_likelihood_trust_A <- cor.test(groupA_data_clean$Likelihood, groupA_data_clean$Trust)
# Create a table to display the correlation tests
correlation_test_results_A <- tibble(
Variables = c("Quality & Likelihood", "Quality & Trust", "Likelihood & Trust"),
Correlation = c(
cor_test_quality_likelihood_A$estimate,
cor_test_quality_trust_A$estimate,
cor_test_likelihood_trust_A$estimate
),
`p-value` = c(
cor_test_quality_likelihood_A$p.value,
cor_test_quality_trust_A$p.value,
cor_test_likelihood_trust_A$p.value
),
`Significant?` = c(
ifelse(cor_test_quality_likelihood_A$p.value < 0.05, "Yes", "No"),
ifelse(cor_test_quality_trust_A$p.value < 0.05, "Yes", "No"),
ifelse(cor_test_likelihood_trust_A$p.value < 0.05, "Yes", "No")
)
)
knitr::kable(correlation_test_results_A, caption = "Correlation Tests for Group A - Written Review")
# Calculate correlation coefficients for Group B
cor_matrix_B <- cor(groupB_data_clean, use = "pairwise.complete.obs")
# Display the correlation matrix
cor_matrix_B %>% round(2) %>% knitr::kable(caption = "Correlation Matrix for Group B - # of Reviews")
# Test significance of correlations
cor_test_quality_likelihood_B <- cor.test(groupB_data_clean$Quality, groupB_data_clean$Likelihood)
cor_test_quality_trust_B <- cor.test(groupB_data_clean$Quality, groupB_data_clean$Trust)
cor_test_likelihood_trust_B <- cor.test(groupB_data_clean$Likelihood, groupB_data_clean$Trust)
# Create a table to display the correlation tests
correlation_test_results_B <- tibble(
Variables = c("Quality & Likelihood", "Quality & Trust", "Likelihood & Trust"),
Correlation = c(
cor_test_quality_likelihood_B$estimate,
cor_test_quality_trust_B$estimate,
cor_test_likelihood_trust_B$estimate
),
`p-value` = c(
