library(dplyr)
library(rsample)     # For data splitting
library(data.table)  # For single feature one-hot encoding
library(nestedcv)    # For full data frame one-hot encoding
library(scales)      # For Min-Max scaling
# Load the dataset
evs <- read.csv("evs.csv", stringsAsFactors = TRUE)
evs <- evs %>% select(-id)
head(evs)
# One-hot encoding the categorical features
# Creates dummy variables for the "drive" column
onehot_drive <- model.matrix(~ drive - 1, data = evs) %>%
as.data.frame()
# Preview the encoded drive features
head(onehot_drive)
# One-hot encoding the full dataset
# This removes the first level as the baseline for all categorical features
onehot_evs <- nestedcv::one_hot(as.data.table(evs))
# Preview the encoded dataset
head(onehot_evs)
# Convert the one-hot encoded data to a numeric matrix
onehotnp_evs <- as.matrix(onehot_evs)
# Min-max scaling
X <- onehotnp_evs
X_scaled <- apply(X, 2, function(x) rescale(x, to = c(0, 1)))
# Round to 2 decimal places
X_scaled <- round(X_scaled, 2)
head(X_scaled)
# Separating data into training and test sets
# Assuming the drive column was one-hot encoded and we want to use one of them as target
# Adjust the column index based on which column is your target variable
# For example, if "driveFront" or "driveRear" is the last column:
y <- X_scaled[, ncol(X_scaled)]  # Target variable
Phi <- X_scaled[, -ncol(X_scaled)]  # Features (everything except target)
# Add a bias column
Phi <- cbind(bias = 1, Phi)
# Split the data (60% training, 40% test to match your Python code)
set.seed(123)
train_indices <- sample(1:nrow(X), size = round(nrow(X) * 0.6), replace = FALSE)
Phi_train <- Phi[train_indices, ]
Phi_test <- Phi[-train_indices, ]
y_train <- y[train_indices]
y_test <- y[-train_indices]
# Training data
head(Phi_train)
y_train
# Testing data
head(Phi_test)
y_test
library(dplyr)
library(rsample)     # For data splitting
library(data.table)  # For single feature one-hot encoding
library(nestedcv)    # For full data frame one-hot encoding
library(scales)      # For Min-Max scaling
evs <- read.csv("evs.csv", stringsAsFactors = TRUE)
# Remove id column
evs <- evs %>% select(-id)
# One-hot encoding the categorical features
# Creates dummy variables for the "class" column
evs <- model.matrix(~ class - 1, data = evs) %>%
as.data.frame() %>%
# Preview the encoded dataset
head(evs)
